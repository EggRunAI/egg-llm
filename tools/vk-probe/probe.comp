#version 450
// Minimal SSBO write probe: each invocation writes its global index (+1) into
// a storage buffer. Correct GPU result is data[i] == i+1. A zero means the
// GPU's write never reached the buffer the host reads back (egg blob-sync
// direction bug). +1 keeps "zero" unambiguous (no invocation legitimately
// writes 0).
layout(local_size_x = 64) in;
layout(std430, set = 0, binding = 0) buffer B { uint data[]; };
void main() {
    uint i = gl_GlobalInvocationID.x;
    data[i] = i + 1u;
}
