#version 450
// Read-modify-write probe: each invocation READS data[i] (host-uploaded input)
// and writes data[i]+1. Tests the host→GPU direction: if the GPU sees the
// guest's uploaded bytes, result is input+1; if it reads stale zeros (input not
// synced to the GPU), result is 1 everywhere — the "weights never reached the
// GPU" failure that yields constant logits in llama.
layout(local_size_x = 64) in;
layout(std430, set = 0, binding = 0) buffer B { uint data[]; };
void main() {
    uint i = gl_GlobalInvocationID.x;
    data[i] = data[i] + 1u;
}
