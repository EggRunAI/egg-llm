# Single source of truth for the pinned llama.cpp build.
# Sourced by build.sh / clean.sh, parsed by build.rs.
# LLAMA_COMMIT and LLAMA_BUILD must refer to the same upstream release:
# LLAMA_BUILD is the release tag (bNNNN) for LLAMA_COMMIT, and also names the
# staged lib dir at bin/llama-${LLAMA_BUILD}.
LLAMA_COMMIT=f3e182816421c648188b5eab269853bf1531d950
LLAMA_BUILD=b9670
